<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>AI Search Readiness Audit — {{domain}}</title>
<style>
  :root {
    --bg: #0b0d12;
    --panel: #11141b;
    --panel-2: #161a23;
    --ink: #e7ebf3;
    --ink-dim: #9aa3b2;
    --accent: #7c5cff;
    --accent-2: #22d3ee;
    --good: #34d399;
    --warn: #fbbf24;
    --bad: #f87171;
    --line: #232838;
    --radius: 14px;
  }
  @media (prefers-color-scheme: light) {
    :root {
      --bg: #f7f8fb;
      --panel: #ffffff;
      --panel-2: #f1f3f8;
      --ink: #11141b;
      --ink-dim: #5a6275;
      --line: #e4e7ef;
    }
  }
  * { box-sizing: border-box; }
  html, body { background: var(--bg); color: var(--ink); margin: 0; }
  body {
    font: 15px/1.55 -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", system-ui, sans-serif;
    padding: 40px 24px 80px;
  }
  .wrap { max-width: 1080px; margin: 0 auto; }
  header { display: flex; justify-content: space-between; align-items: flex-end; gap: 24px; margin-bottom: 28px; flex-wrap: wrap; }
  header h1 { font-size: 28px; margin: 0 0 6px; letter-spacing: -0.01em; }
  header .meta { color: var(--ink-dim); font-size: 13px; }
  header .brand { font-size: 12px; color: var(--ink-dim); text-align: right; }
  header .brand a { color: var(--accent-2); text-decoration: none; }

  .hero {
    display: grid; grid-template-columns: 320px 1fr; gap: 20px;
    background: var(--panel); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 24px; margin-bottom: 20px;
  }
  @media (max-width: 760px) { .hero { grid-template-columns: 1fr; } }

  .gauge { display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .gauge .ring {
    --size: 200px; --val: {{site_score}}; --max: 100;
    width: var(--size); height: var(--size); border-radius: 50%;
    background:
      conic-gradient(var(--accent) calc(var(--val) * 3.6deg), var(--panel-2) 0);
    display: grid; place-items: center; position: relative;
  }
  .gauge .ring::before {
    content: ""; width: 78%; height: 78%; background: var(--panel); border-radius: 50%; position: absolute;
  }
  .gauge .num { position: relative; font-size: 56px; font-weight: 700; letter-spacing: -0.02em; }
  .gauge .num small { font-size: 18px; color: var(--ink-dim); font-weight: 500; }
  .gauge .label { margin-top: 10px; color: var(--ink-dim); font-size: 13px; text-transform: uppercase; letter-spacing: 0.08em; }

  .charts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
  @media (max-width: 760px) { .charts-row { grid-template-columns: 1fr; } }
  .chart-card { background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius); padding: 20px 24px; }
  .chart-card h3 { font-size: 13px; color: var(--ink-dim); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 14px; font-weight: 600; }
  .chart-card svg { display: block; width: 100%; }

  .headline { font-size: 17px; line-height: 1.55; }
  .headline strong { color: var(--accent-2); }

  .dims { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 20px; }
  @media (max-width: 760px) { .dims { grid-template-columns: repeat(2, 1fr); } }
  .dim {
    background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius);
    padding: 14px 16px;
  }
  .dim .name { font-size: 11px; color: var(--ink-dim); text-transform: uppercase; letter-spacing: 0.08em; }
  .dim .val { font-size: 24px; font-weight: 700; margin-top: 4px; }
  .dim .val small { font-size: 13px; color: var(--ink-dim); font-weight: 500; }
  .dim .bar { height: 6px; background: var(--panel-2); border-radius: 4px; overflow: hidden; margin-top: 10px; }
  .dim .bar span { display: block; height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent-2)); }
  .dim .blocker { font-size: 12px; color: var(--ink-dim); margin-top: 8px; line-height: 1.4; }

  section.card {
    background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius);
    padding: 22px 24px; margin-bottom: 16px;
  }
  section.card h2 { font-size: 18px; margin: 0 0 14px; letter-spacing: -0.01em; }

  .fixes { display: grid; gap: 10px; }
  .fix { display: grid; grid-template-columns: 28px 1fr auto; gap: 12px; align-items: center; padding: 12px; background: var(--panel-2); border-radius: 10px; }
  .fix .rank { font-weight: 700; color: var(--accent); font-size: 16px; }
  .fix .text { font-size: 14px; line-height: 1.5; }
  .fix .meta { font-size: 12px; color: var(--ink-dim); white-space: nowrap; }
  .pill { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 600; }
  .pill.s { background: rgba(52, 211, 153, 0.15); color: var(--good); }
  .pill.m { background: rgba(251, 191, 36, 0.18); color: var(--warn); }
  .pill.l { background: rgba(248, 113, 113, 0.18); color: var(--bad); }

  .buckets { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
  @media (max-width: 760px) { .buckets { grid-template-columns: repeat(2, 1fr); } }
  .bucket { background: var(--panel-2); border-radius: 10px; padding: 14px; text-align: center; }
  .bucket .b-num { font-size: 28px; font-weight: 700; }
  .bucket .b-label { font-size: 12px; color: var(--ink-dim); text-transform: uppercase; letter-spacing: 0.06em; margin-top: 4px; }
  .bucket.strong .b-num { color: var(--good); }
  .bucket.decent .b-num { color: var(--accent-2); }
  .bucket.weak .b-num { color: var(--warn); }
  .bucket.invisible .b-num { color: var(--bad); }

  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  table th, table td { text-align: left; padding: 10px 12px; border-bottom: 1px solid var(--line); }
  table th { font-size: 11px; color: var(--ink-dim); text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600; }
  table tbody tr:hover { background: var(--panel-2); }
  table td.score { font-variant-numeric: tabular-nums; font-weight: 600; }
  table td.score.bad { color: var(--bad); }
  table td.score.warn { color: var(--warn); }
  table td.score.good { color: var(--good); }
  table td a { color: var(--accent-2); text-decoration: none; word-break: break-all; }

  .artifacts { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
  @media (max-width: 760px) { .artifacts { grid-template-columns: 1fr; } }
  .artifact { display: flex; align-items: center; gap: 10px; padding: 12px 14px; background: var(--panel-2); border-radius: 10px; font-size: 13px; }
  .artifact .ico { width: 28px; height: 28px; border-radius: 8px; background: var(--accent); display: grid; place-items: center; color: #fff; font-weight: 700; font-size: 12px; }
  .artifact code { background: transparent; color: var(--ink-dim); font-size: 12px; }

  footer { text-align: center; color: var(--ink-dim); font-size: 12px; margin-top: 32px; }
  footer a { color: var(--accent-2); text-decoration: none; }

  @media print {
    body { padding: 0; }
    .wrap { max-width: none; }
    section.card, .hero, .dim { break-inside: avoid; box-shadow: none; }
  }
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div>
      <h1>AI Search Readiness Audit</h1>
      <div class="meta">{{domain}} · crawled {{crawl_date}} · {{urls_crawled}} URLs · JS rendering {{js_rendering}}</div>
    </div>
    <div class="brand">
      generated by <a href="https://github.com/{{repo_owner}}/ai-search-auditor">ai-search-auditor</a><br>
      <span>Screaming Frog MCP · Claude</span>
    </div>
  </header>

  <div class="hero">
    <div class="gauge">
      <div class="ring"><div class="num">{{site_score}}<small>/100</small></div></div>
      <div class="label">Site score</div>
    </div>
    <div>
      <div style="font-size:11px; color: var(--ink-dim); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px;">Headline finding</div>
      <p class="headline"><strong>{{headline_gap}}</strong> {{headline_consequence}} {{headline_action}}</p>
      <div style="margin-top: 14px; font-size: 13px; color: var(--ink-dim);">Top-50 most-linked pages average <strong style="color: var(--ink);">{{top50_avg}}/100</strong>.</div>
    </div>
  </div>

  <div class="dims">
    <div class="dim">
      <div class="name">Bot Access</div>
      <div class="val">{{bot_access}}<small>/20</small></div>
      <div class="bar"><span style="width: {{bot_access_pct}}%"></span></div>
      <div class="blocker">{{bot_access_blocker}}</div>
    </div>
    <div class="dim">
      <div class="name">Discovery</div>
      <div class="val">{{discovery}}<small>/20</small></div>
      <div class="bar"><span style="width: {{discovery_pct}}%"></span></div>
      <div class="blocker">{{discovery_blocker}}</div>
    </div>
    <div class="dim">
      <div class="name">Structure</div>
      <div class="val">{{structure}}<small>/20</small></div>
      <div class="bar"><span style="width: {{structure_pct}}%"></span></div>
      <div class="blocker">{{structure_blocker}}</div>
    </div>
    <div class="dim">
      <div class="name">Citability</div>
      <div class="val">{{citability}}<small>/20</small></div>
      <div class="bar"><span style="width: {{citability_pct}}%"></span></div>
      <div class="blocker">{{citability_blocker}}</div>
    </div>
    <div class="dim">
      <div class="name">Authority</div>
      <div class="val">{{authority}}<small>/20</small></div>
      <div class="bar"><span style="width: {{authority_pct}}%"></span></div>
      <div class="blocker">{{authority_blocker}}</div>
    </div>
  </div>

  {{delta_html}}

  <div class="charts-row">
    <div class="chart-card">
      <h3>Dimension radar</h3>
      <svg id="radar" viewBox="0 0 240 220" aria-label="Radar chart of 5 audit dimensions"></svg>
    </div>
    <div class="chart-card">
      <h3>Score distribution</h3>
      <svg id="histogram" viewBox="0 0 340 200" aria-label="Histogram of page scores"></svg>
    </div>
  </div>

  <script>
  (function() {
    var CS = getComputedStyle(document.documentElement);
    var accent  = CS.getPropertyValue('--accent').trim()   || '#7c5cff';
    var accent2 = CS.getPropertyValue('--accent-2').trim() || '#22d3ee';
    var panel2  = CS.getPropertyValue('--panel-2').trim()  || '#161a23';
    var ink     = CS.getPropertyValue('--ink').trim()      || '#e7ebf3';
    var inkDim  = CS.getPropertyValue('--ink-dim').trim()  || '#9aa3b2';
    var good    = CS.getPropertyValue('--good').trim()     || '#34d399';
    var warn    = CS.getPropertyValue('--warn').trim()     || '#fbbf24';
    var bad     = CS.getPropertyValue('--bad').trim()      || '#f87171';

    // ── Radar chart ──────────────────────────────────────────────────────────
    var dims = [
      { label: 'Bot Access', val: {{bot_access}},  max: 20 },
      { label: 'Discovery',  val: {{discovery}},   max: 20 },
      { label: 'Structure',  val: {{structure}},   max: 20 },
      { label: 'Citability', val: {{citability}},  max: 20 },
      { label: 'Authority',  val: {{authority}},   max: 20 }
    ];
    var ns = 'http://www.w3.org/2000/svg';
    var svg = document.getElementById('radar');
    var cx = 120, cy = 112, r = 80;
    var n = dims.length;
    function polar(cx, cy, r, i, total) {
      var angle = (Math.PI * 2 * i / total) - Math.PI / 2;
      return [cx + r * Math.cos(angle), cy + r * Math.sin(angle)];
    }
    // Grid rings
    [0.25, 0.5, 0.75, 1].forEach(function(pct) {
      var pts = dims.map(function(_, i) { return polar(cx, cy, r * pct, i, n).join(','); }).join(' ');
      var poly = document.createElementNS(ns, 'polygon');
      poly.setAttribute('points', pts);
      poly.setAttribute('fill', 'none');
      poly.setAttribute('stroke', panel2);
      poly.setAttribute('stroke-width', '1');
      svg.appendChild(poly);
    });
    // Axis lines
    dims.forEach(function(_, i) {
      var pt = polar(cx, cy, r, i, n);
      var line = document.createElementNS(ns, 'line');
      line.setAttribute('x1', cx); line.setAttribute('y1', cy);
      line.setAttribute('x2', pt[0]); line.setAttribute('y2', pt[1]);
      line.setAttribute('stroke', panel2); line.setAttribute('stroke-width', '1');
      svg.appendChild(line);
    });
    // Data polygon
    var dataPts = dims.map(function(d, i) {
      return polar(cx, cy, r * (d.val / d.max), i, n).join(',');
    }).join(' ');
    var dataPoly = document.createElementNS(ns, 'polygon');
    dataPoly.setAttribute('points', dataPts);
    dataPoly.setAttribute('fill', accent);
    dataPoly.setAttribute('fill-opacity', '0.2');
    dataPoly.setAttribute('stroke', accent);
    dataPoly.setAttribute('stroke-width', '2');
    svg.appendChild(dataPoly);
    // Dots
    dims.forEach(function(d, i) {
      var pt = polar(cx, cy, r * (d.val / d.max), i, n);
      var circle = document.createElementNS(ns, 'circle');
      circle.setAttribute('cx', pt[0]); circle.setAttribute('cy', pt[1]);
      circle.setAttribute('r', '4');
      circle.setAttribute('fill', accent2);
      svg.appendChild(circle);
    });
    // Labels
    dims.forEach(function(d, i) {
      var pt = polar(cx, cy, r + 22, i, n);
      var text = document.createElementNS(ns, 'text');
      text.setAttribute('x', pt[0]); text.setAttribute('y', pt[1]);
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('dominant-baseline', 'middle');
      text.setAttribute('font-size', '11');
      text.setAttribute('fill', inkDim);
      text.textContent = d.label + ' ' + d.val;
      svg.appendChild(text);
    });

    // ── Histogram ────────────────────────────────────────────────────────────
    var buckets = {{histogram_buckets_json}};
    // buckets: array of {range:"0-9", count:N} for ranges 0-9,10-19,...,90-100
    var hsvg = document.getElementById('histogram');
    var hW = 340, hH = 200, padL = 28, padB = 36, padT = 12, padR = 12;
    var chartW = hW - padL - padR;
    var chartH = hH - padB - padT;
    var maxCount = Math.max.apply(null, buckets.map(function(b) { return b.count; })) || 1;
    var barW = chartW / buckets.length;
    // Score color by range midpoint
    function barColor(idx) {
      var mid = idx * 10 + 5;
      if (mid >= 80) return good;
      if (mid >= 60) return accent2;
      if (mid >= 40) return warn;
      return bad;
    }
    buckets.forEach(function(b, i) {
      var bh = Math.round((b.count / maxCount) * chartH);
      var x = padL + i * barW + 2;
      var y = padT + chartH - bh;
      var rect = document.createElementNS(ns, 'rect');
      rect.setAttribute('x', x);
      rect.setAttribute('y', y);
      rect.setAttribute('width', barW - 4);
      rect.setAttribute('height', bh);
      rect.setAttribute('fill', barColor(i));
      rect.setAttribute('rx', '3');
      hsvg.appendChild(rect);
      // Count label on bar if space
      if (bh > 16 && b.count > 0) {
        var lbl = document.createElementNS(ns, 'text');
        lbl.setAttribute('x', x + (barW - 4) / 2);
        lbl.setAttribute('y', y + 11);
        lbl.setAttribute('text-anchor', 'middle');
        lbl.setAttribute('font-size', '9');
        lbl.setAttribute('fill', '#fff');
        lbl.textContent = b.count;
        hsvg.appendChild(lbl);
      }
      // X axis label every 2 bars
      if (i % 2 === 0) {
        var xlabel = document.createElementNS(ns, 'text');
        xlabel.setAttribute('x', x + (barW - 4) / 2);
        xlabel.setAttribute('y', padT + chartH + 14);
        xlabel.setAttribute('text-anchor', 'middle');
        xlabel.setAttribute('font-size', '9');
        xlabel.setAttribute('fill', inkDim);
        xlabel.textContent = i * 10;
        hsvg.appendChild(xlabel);
      }
    });
    // Y axis baseline
    var baseline = document.createElementNS(ns, 'line');
    baseline.setAttribute('x1', padL); baseline.setAttribute('y1', padT + chartH);
    baseline.setAttribute('x2', hW - padR); baseline.setAttribute('y2', padT + chartH);
    baseline.setAttribute('stroke', panel2); baseline.setAttribute('stroke-width', '1');
    hsvg.appendChild(baseline);
  })();
  </script>

  <section class="card">
    <h2>Top 5 fixes that move the needle</h2>
    <div class="fixes">{{fixes_html}}</div>
  </section>

  <section class="card">
    <h2>Page buckets</h2>
    <div class="buckets">
      <div class="bucket strong"><div class="b-num">{{bucket_strong}}</div><div class="b-label">Strong 80–100</div></div>
      <div class="bucket decent"><div class="b-num">{{bucket_decent}}</div><div class="b-label">Decent 60–79</div></div>
      <div class="bucket weak"><div class="b-num">{{bucket_weak}}</div><div class="b-label">Weak 40–59</div></div>
      <div class="bucket invisible"><div class="b-num">{{bucket_invisible}}</div><div class="b-label">Invisible 0–39</div></div>
    </div>
  </section>

  <section class="card">
    <h2>Priority fix list — top pages below Decent (&lt; 60) by inlink count</h2>
    <table>
      <thead><tr><th>URL</th><th>Inlinks</th><th>Score</th><th>Top miss</th></tr></thead>
      <tbody>{{priority_rows_html}}</tbody>
    </table>
  </section>

  <section class="card">
    <h2>Generated artifacts</h2>
    <div class="artifacts">{{artifacts_html}}</div>
  </section>

  <footer>
    Re-audit in 4 weeks after shipping the top fixes. Expected post-fix site score:
    <strong style="color: var(--ink);">{{expected_post_fix_score}}/100</strong>.
    <br>
    Rubric: <a href="https://github.com/{{repo_owner}}/ai-search-auditor/blob/main/.claude/skills/ai-search-audit/rubric.md">deterministic, auditable</a> · v{{rubric_version}}.
    <br style="margin-bottom: 6px;">
    <span style="font-size: 11px; color: var(--ink-dim); max-width: 700px; display: inline-block; margin-top: 8px; line-height: 1.5;">
      Scope: optimized for citations in ChatGPT, Claude, and Perplexity.
      For Google AI Overviews, <a href="https://developers.google.com/search/docs/fundamentals/ai-optimization-guide" style="color: var(--ink-dim);">Google's own guidance</a> prioritizes foundational SEO over llms.txt and structured data -- use Search Console for Google AI signals.
    </span>
  </footer>

</div>
</body>
</html>
