# Reports for real sites. Keep examples and explicitly allowlisted showcases; ignore audits of actual domains.
reports/*
!reports/.gitkeep
!reports/example.com/
# anthropic.com is committed as a real-world showcase audit. Exception granted intentionally.
# See CONTRIBUTING.md §Example audits for the policy on committing real-domain reports.
!reports/anthropic.com/

# Screaming Frog crawl files
*.seospider
*.dbseospider

# Node (only relevant if using community MCP)
node_modules/
package-lock.json
.npm

# Env / secrets
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Claude Code session/local
.claude/settings.local.json

# Personal / non-repo working files (move to .git/info/exclude for your own machine)
LINKEDIN_POST.md
_post/
.venv-sfmcp/
.mcp.json.native-v24.bak
