{
  "mcpServers": {
    "screaming-frog": {
      "command": "uvx",
      "args": ["--python", "3.13", "--from", "screaming-frog-mcp", "screaming-frog-mcp"],
      "env": {
        "_comment": "NOTE: Linux paths are case-sensitive. The binary is typically 'screamingfrogseospider' (all lowercase). Verify with: which screamingfrogseospider",
        "SF_CLI_PATH": "/usr/bin/screamingfrogseospider"
      }
    }
  }
}
